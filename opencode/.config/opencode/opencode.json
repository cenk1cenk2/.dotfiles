{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "enabled_providers": ["openai", "kilic"],
  "autoupdate": false,
  "permission": {
    "*": "ask",
    "edit": {
      "*": "ask"
    },
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git log": "allow",
      "git diff": "allow",
      "git show": "allow",
      "git branch": "allow",
      "git rev-parse": "allow",
      "git remote -v": "allow",
      "git tag": "allow",
      "ls": "allow",
      "wc": "allow",
      "stat": "allow",
      "which": "allow",
      "file": "allow",
      "pwd": "allow",
      "type": "allow"
    },
    "webfetch": "allow",
    "doom_loop": "ask",
    "external_directory": "allow"
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "reasoningEffort": "high"
          }
        },
        "gpt-5.3-codex-spark": {
          "options": {
            "reasoningEffort": "high"
          }
        }
      }
    },
    "kilic": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "kilic",
      "options": {
        "baseURL": "https://ai.kilic.dev/ollama/v1",
        "apiKey": "{env:AI_KILIC_DEV_API_KEY}"
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro"
        },
        "glm-5.2:cloud": {
          "name": "GLM 5.2 Cloud"
        },
        "kimi-k2.7-code:cloud": {
          "name": "Kimi K2.7 Code Cloud"
        },
        "minimax-m3:cloud": {
          "name": "Minimax M3 Cloud"
        },
        "gemma4:31b-cloud": {
          "name": "Gemma4 Cloud"
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash"
        },
        "gemma4:e2b": {
          "name": "Gemma4 e2b"
        }
      }
    }
  }
}
