{
  "$schema": "https://opencode.ai/config.json",
  "model": "kilic/glm-5.2:cloud",
  "small_model": "kilic/gemma4:31b-cloud",
  "enabled_providers": ["openai", "kilic"],
  "autoupdate": false,
  "instructions": ["CLAUDE.md", "AGENTS.md"],
  "compaction": { "auto": true, "tail_turns": 10 },
  "experimental": {
    "continue_loop_on_deny": true,
    "batch_tool": true,
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "todowrite": "allow",
    "question": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "task": "allow",
    "external_directory": "allow",
    "doom_loop": "ask",
    "edit": {
      "~/.claude/plans/**": "allow",
      "*": "ask",
    },
    "bash": {
      "git status": "allow",
      "git log": "allow",
      "git diff": "allow",
      "git show": "allow",
      "git branch": "allow",
      "git rev-parse": "allow",
      "git remote -v": "allow",
      "git tag": "allow",
      "ls": "allow",
      "wc": "allow",
      "stat": "allow",
      "which": "allow",
      "file": "allow",
      "pwd": "allow",
      "type": "allow",
      "*": "ask",
    },
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "reasoningEffort": "high",
          },
        },
        "gpt-5.3-codex-spark": {
          "options": {
            "reasoningEffort": "high",
          },
        },
      },
    },
    "kilic": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "kilic",
      "options": {
        "baseURL": "https://ai.kilic.dev/ollama/v1",
        "apiKey": "{env:AI_KILIC_DEV_API_KEY}",
      },
      "models": {
        "deepseek-v4-pro:cloud": {
          "name": "DeepSeek V4 Pro",
        },
        "glm-5.2:cloud": {
          "name": "GLM 5.2 Cloud",
          "options": {
            "reasoningEffort": "max",
          },
        },
        "kimi-k2.7-code:cloud": {
          "name": "Kimi K2.7 Code Cloud",
        },
        "minimax-m3:cloud": {
          "name": "Minimax M3 Cloud",
        },
        "gemma4:31b-cloud": {
          "name": "Gemma4 Cloud",
        },
        "deepseek-v4-flash:cloud": {
          "name": "DeepSeek V4 Flash",
        },
        "gemma4:e2b": {
          "name": "Gemma4 e2b",
        },
      },
    },
  },
}
