#!/usr/bin/env python3
"""Switch audio sinks and display profiles."""

from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from enum import StrEnum
from pathlib import Path

# Reuse the Hyprland scripts lib (socket IPC instead of hyprctl forks).
# Both live in the same dotfiles repo, so the path is stable; kanshi and
# sound paths never need it, hence the soft failure.
sys.path.insert(0, str(Path.home() / ".config/hypr/scripts"))
try:
    from lib import Hyprctl  # noqa: E402
except ImportError:
    Hyprctl = None

class DisplayBackend(StrEnum):
    KANSHI = "kanshi"
    NATIVE = "native"

class Jumpy:
    AUDIO_ICON = "/usr/share/icons/Adwaita/scalable/devices/audio-headphones.svg"
    DISPLAY_ICON = "/usr/share/icons/Adwaita/scalable/devices/video-display.svg"
    KANSHI_CONFIG = Path.home() / ".config/kanshi/config"
    DISPLAY_MODULE = "outputs.profiles"
    PROFILES_LUA = Path.home() / ".config/hypr/outputs/profiles.lua"

    def _notify(self, title: str, message: str, icon: str) -> None:
        subprocess.run(
            ["notify-send", title, message, "-i", icon],
            check=False,
        )

    def _pw_nodes(self) -> list[dict]:
        proc = subprocess.run(["pw-dump"], capture_output=True, text=True, check=True)
        return [
            n
            for n in json.loads(proc.stdout)
            if n.get("type") == "PipeWire:Interface:Node"
        ]

    def sound_ls(self) -> None:
        print("Available sources are listed below.")
        print()
        print("media.class,alsa.card_name,media.name")
        print("-------------------------------------")
        for node in self._pw_nodes():
            props = node.get("info", {}).get("props", {})
            row = ",".join(
                json.dumps(props.get(k, ""))
                for k in ("media.class", "alsa.card_name", "media.name")
            )
            print(row)

    def sound_apply(self, media_class: str, card_name: str) -> None:
        for node in self._pw_nodes():
            props = node.get("info", {}).get("props", {})
            if props.get("media.class") != media_class:
                continue
            if card_name in (props.get("alsa.card_name"), props.get("media.name")):
                subprocess.run(["wpctl", "set-default", str(node["id"])], check=True)
                self._notify(f"wireplumber [{media_class}]", card_name, self.AUDIO_ICON)
                return
        print(
            f"jumpy sound: no node matches {media_class!r} + {card_name!r}",
            file=sys.stderr,
        )
        sys.exit(1)

    def _ensure_native(self) -> Hyprctl:
        # Guard the `require`-driven native paths (reload / switch): fail
        # unless profiles.lua is ALREADY loaded in a running instance.
        # Probed through `package.loaded` so the check never *loads* the
        # module itself — force-loading it via `require` while kanshi is
        # still running would wire profiles.lua's hotplug hooks alongside
        # kanshi, and the two would fight over every monitor event. The
        # lib self-discovers the instance socket, so bare-env callers
        # (SSH, systemd, home-assistant) work without
        # HYPRLAND_INSTANCE_SIGNATURE.
        if Hyprctl is None:
            print(
                "jumpy display: hyprland scripts lib not found (~/.config/hypr/scripts).",
                file=sys.stderr,
            )
            sys.exit(1)
        hypr = Hyprctl()
        if not hypr.eval(f'assert(package.loaded["{self.DISPLAY_MODULE}"])'):
            print(
                "jumpy display: --backend native needs a running Hyprland with profiles.lua "
                "loaded (uncomment its require in ~/.config/hypr/outputs/init.lua).",
                file=sys.stderr,
            )
            sys.exit(1)

        return hypr

    def display_ls(self, backend: DisplayBackend) -> None:
        if backend is DisplayBackend.NATIVE:
            # Reading the file is side-effect-free, so listing doesn't need
            # the load guard — the .lua file is the source of truth (0.56
            # still can't return a Lua value through hyprctl).
            text = self.PROFILES_LUA.read_text()
            for match in re.finditer(r'\["([^"]+)"\]\s*=\s*\{', text):
                print(match.group(1))
            return

        text = self.KANSHI_CONFIG.read_text()
        seen: set[str] = set()
        for match in re.finditer(r"^\s*profile\s+(\S+)\s*\{", text, re.M):
            name = match.group(1)
            if name not in seen:
                seen.add(name)
                print(name)

    def display_reload(self, backend: DisplayBackend) -> None:
        if backend is DisplayBackend.NATIVE:
            hypr = self._ensure_native()
            if not hypr.eval(f'require("{self.DISPLAY_MODULE}").auto_apply()'):
                print("jumpy display: reload failed.", file=sys.stderr)
                sys.exit(1)
            return

        try:
            subprocess.run(["kanshictl", "reload"], check=True, timeout=10)
        except subprocess.TimeoutExpired:
            # Hyprland 0.56 never ACKs a wlr-output-management apply that
            # changes nothing, so kanshi's reload hangs whenever the
            # config is already active. Already-applied is success.
            print(
                "jumpy display: kanshictl reload timed out — state already active.",
                file=sys.stderr,
            )

    def display_switch(self, profile: str, backend: DisplayBackend) -> None:
        if backend is DisplayBackend.NATIVE:
            hypr = self._ensure_native()
            # profiles.lua's apply() emits its own "Applied profile" notify.
            if not hypr.eval(f'require("{self.DISPLAY_MODULE}").apply({json.dumps(profile)})'):
                print(f"jumpy display: switch to {profile} failed.", file=sys.stderr)
                sys.exit(1)
            return

        subprocess.run(
            ["/etc/udev/scripts/wayland-user.sh", "kanshictl", "switch", profile],
            check=True,
        )
        self._notify("display", f"Trigger profile {profile}.", self.DISPLAY_ICON)

    def _build_parser(self) -> argparse.ArgumentParser:
        parser = argparse.ArgumentParser(
            prog="jumpy",
            description="Switch audio sinks and display profiles.",
        )
        sub = parser.add_subparsers(dest="command", required=True)

        sound = sub.add_parser(
            "sound",
            help="Set default audio device via wireplumber.",
            description=(
                "Set default audio using wireplumber.\n"
                "Usage: jumpy sound [media.class] [alsa.card_name|media.name]\n"
                "Example: jumpy sound 'Audio/Sink' 'Scarlett 8i6 USB'\n\n"
                "List available devices and their classes:\n"
                "Usage: jumpy sound ls"
            ),
            formatter_class=argparse.RawDescriptionHelpFormatter,
        )
        sound.add_argument("args", nargs="*")

        display = sub.add_parser(
            "display",
            help="Apply / list Hyprland monitor profiles.",
            description=(
                "List available profiles: jumpy display ls\n"
                "Re-run auto-match: jumpy display reload\n"
                "Apply a profile: jumpy display [profile]"
            ),
            formatter_class=argparse.RawDescriptionHelpFormatter,
        )
        display.add_argument(
            "--backend",
            choices=list(DisplayBackend),
            type=DisplayBackend,
            default=DisplayBackend.KANSHI,
            help="Profile backend: kanshi (default) or native profiles.lua.",
        )
        display.add_argument("args", nargs="*")

        return parser

    def run(self, argv: list[str] | None = None) -> None:
        parser = self._build_parser()
        ns = parser.parse_args(argv)

        match ns.command:
            case "sound":
                match ns.args:
                    case [] | ["help"]:
                        parser.parse_args(["sound", "--help"])
                    case ["ls"]:
                        self.sound_ls()
                    case [media_class, card_name]:
                        self.sound_apply(media_class, card_name)
                    case _:
                        parser.parse_args(["sound", "--help"])
                        sys.exit(2)
            case "display":
                match ns.args:
                    case [] | ["help"]:
                        parser.parse_args(["display", "--help"])
                    case ["ls"]:
                        self.display_ls(ns.backend)
                    case ["reload"]:
                        self.display_reload(ns.backend)
                    case [profile]:
                        self.display_switch(profile, ns.backend)
                    case _:
                        parser.parse_args(["display", "--help"])
                        sys.exit(2)

if __name__ == "__main__":
    Jumpy().run()
