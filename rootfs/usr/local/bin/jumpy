#!/usr/bin/env python3
"""Switch audio sinks and display profiles."""

from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from pathlib import Path

class Jumpy:
    AUDIO_ICON = "/usr/share/icons/Adwaita/scalable/devices/audio-headphones.svg"
    DISPLAY_MODULE = "outputs.profiles"
    PROFILES_LUA = Path.home() / ".config/hypr/outputs/profiles.lua"

    def _notify(self, title: str, message: str, icon: str) -> None:
        subprocess.run(
            ["notify-send", title, message, "-i", icon],
            check=False,
        )

    def _pw_nodes(self) -> list[dict]:
        proc = subprocess.run(["pw-dump"], capture_output=True, text=True, check=True)
        return [
            n
            for n in json.loads(proc.stdout)
            if n.get("type") == "PipeWire:Interface:Node"
        ]

    def sound_ls(self) -> None:
        print("Available sources are listed below.")
        print()
        print("media.class,alsa.card_name,media.name")
        print("-------------------------------------")
        for node in self._pw_nodes():
            props = node.get("info", {}).get("props", {})
            row = ",".join(
                json.dumps(props.get(k, ""))
                for k in ("media.class", "alsa.card_name", "media.name")
            )
            print(row)

    def sound_apply(self, media_class: str, card_name: str) -> None:
        for node in self._pw_nodes():
            props = node.get("info", {}).get("props", {})
            if props.get("media.class") != media_class:
                continue
            if card_name in (props.get("alsa.card_name"), props.get("media.name")):
                subprocess.run(["wpctl", "set-default", str(node["id"])], check=True)
                self._notify(f"wireplumber [{media_class}]", card_name, self.AUDIO_ICON)
                return
        print(
            f"jumpy sound: no node matches {media_class!r} + {card_name!r}",
            file=sys.stderr,
        )
        sys.exit(1)

    def _hyprctl_eval(self, expr: str) -> str:
        # `-i 0` makes hyprctl walk its own instance list and pick the
        # first running compositor. Lets non-interactive callers (SSH,
        # systemd units, home-assistant shell_command) work without
        # HYPRLAND_INSTANCE_SIGNATURE in the environment.
        proc = subprocess.run(
            ["hyprctl", "-i", "0", "eval", expr],
            capture_output=True,
            text=True,
            check=True,
        )
        return proc.stdout

    def display_ls(self) -> None:
        # Why we parse the Lua file instead of asking Hyprland:
        # Hyprland 0.55 has no way to return a Lua value through
        # `hyprctl`. `hyprctl eval EXPR` runs `guardedPCall(..., 0, 0)`
        # (`nresults=0`) and always echoes "ok" / error-text — the
        # return value is discarded. `print()` goes to Hyprland's log,
        # not the request socket. There's no `hl.ipc.handler`, no
        # `hyprctl call`, and `-j eval` is not JSON-aware.
        # See: src/debug/HyprCtl.cpp `evalRequest`,
        #      src/config/lua/ConfigManager.cpp `eval`.
        # The canonical workaround is a tmp-file round-trip via
        # $XDG_RUNTIME_DIR/hypr/$HIS/, but for a static profile dict
        # that's just extra moving parts — the .lua file IS the source
        # of truth. Regex over `["name"] = {` is exact and stable.
        text = self.PROFILES_LUA.read_text()
        for match in re.finditer(r'\["([^"]+)"\]\s*=\s*\{', text):
            print(match.group(1))

    def display_reload(self) -> None:
        self._hyprctl_eval(f'require("{self.DISPLAY_MODULE}").auto_apply()')

    def display_switch(self, profile: str) -> None:
        self._hyprctl_eval(
            f'require("{self.DISPLAY_MODULE}").apply({json.dumps(profile)})'
        )

    def _build_parser(self) -> argparse.ArgumentParser:
        parser = argparse.ArgumentParser(
            prog="jumpy",
            description="Switch audio sinks and display profiles.",
        )
        sub = parser.add_subparsers(dest="command", required=True)

        sound = sub.add_parser(
            "sound",
            help="Set default audio device via wireplumber.",
            description=(
                "Set default audio using wireplumber.\n"
                "Usage: jumpy sound [media.class] [alsa.card_name|media.name]\n"
                "Example: jumpy sound 'Audio/Sink' 'Scarlett 8i6 USB'\n\n"
                "List available devices and their classes:\n"
                "Usage: jumpy sound ls"
            ),
            formatter_class=argparse.RawDescriptionHelpFormatter,
        )
        sound.add_argument("args", nargs="*")

        display = sub.add_parser(
            "display",
            help="Apply / list Hyprland monitor profiles.",
            description=(
                "List available profiles: jumpy display ls\n"
                "Re-run auto-match: jumpy display reload\n"
                "Apply a profile: jumpy display [profile]"
            ),
            formatter_class=argparse.RawDescriptionHelpFormatter,
        )
        display.add_argument("args", nargs="*")

        return parser

    def run(self, argv: list[str] | None = None) -> None:
        parser = self._build_parser()
        ns = parser.parse_args(argv)

        match ns.command:
            case "sound":
                match ns.args:
                    case [] | ["help"]:
                        parser.parse_args(["sound", "--help"])
                    case ["ls"]:
                        self.sound_ls()
                    case [media_class, card_name]:
                        self.sound_apply(media_class, card_name)
                    case _:
                        parser.parse_args(["sound", "--help"])
                        sys.exit(2)
            case "display":
                match ns.args:
                    case [] | ["help"]:
                        parser.parse_args(["display", "--help"])
                    case ["ls"]:
                        self.display_ls()
                    case ["reload"]:
                        self.display_reload()
                    case [profile]:
                        self.display_switch(profile)
                    case _:
                        parser.parse_args(["display", "--help"])
                        sys.exit(2)

if __name__ == "__main__":
    Jumpy().run()
