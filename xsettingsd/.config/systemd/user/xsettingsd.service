[Unit]
Description=XSettings daemon for Wayland XWayland clients
Documentation=man:xsettingsd(1)
PartOf=graphical-session.target
After=wayland-session-waitenv.service wayland-theme.service
Before=graphical-session.target xdg-desktop-autostart.target
ConditionEnvironment=DISPLAY

[Service]
Type=simple
ExecCondition=/bin/sh -c 'command -v xsettingsd'
ExecStart=xsettingsd -c %h/.config/xsettingsd/xsettingsd.conf
Restart=on-failure
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=graphical-session.target
