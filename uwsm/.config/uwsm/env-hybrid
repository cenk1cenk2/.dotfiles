# vim: ft=bash

_card_for_vendor() {
  for vendor in /sys/class/drm/card*/device/vendor; do
    [ -r "$vendor" ] || continue
    [ "$(cat "$vendor")" = "$1" ] || continue

    card_dir="${vendor%/device/vendor}"
    card="${card_dir##*/}"
    [ -e "/dev/dri/$card" ] || continue

    printf '/dev/dri/%s\n' "$card"
    return 0
  done

  return 1
}

_gpu_intel_card="$(_card_for_vendor 0x8086 || true)"
_gpu_nvidia_card="$(_card_for_vendor 0x10de || true)"

if [ -n "$_gpu_intel_card" ]; then
  # Intel only, on purpose: handing the NVIDIA card to the compositor makes
  # Hyprland/Xwayland hold its KMS node, which keeps the dGPU permanently
  # active and defeats fine-grained RTD3 runtime suspend. With the dGPU out of
  # AQ_DRM_DEVICES it suspends when idle and wakes on demand for offloaded
  # work. Cost: outputs wired to the dGPU (HDMI, the muxed eDP) cannot be
  # driven in this profile — USB-C/DP outputs sit on the Intel card and keep
  # working. Use the "Hyprland NVIDIA" session when HDMI is needed.
  export AQ_DRM_DEVICES="$_gpu_intel_card"
  export LIBVA_DRIVER_NAME=iHD

  # EGL enumeration through GLVND loads the NVIDIA vendor library, which opens
  # /dev/nvidia0 in every EGL app (compositor, wallpaper daemon, Chromium apps)
  # and those RM-client handles pin the dGPU awake even with zero contexts.
  # Restricting EGL to Mesa stops the opens entirely; Vulkan enumeration is a
  # separate path, so games still see the NVIDIA ICD, and prime-run GL offload
  # uses the GLX vendor selector, which this does not touch.
  export __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/50_mesa.json

  # GTK4 defaults to its Vulkan renderer, whose device enumeration opens and
  # holds /dev/nvidia0 (seen with swayosd grabbing nvidia-modeset). Forcing the
  # GL renderer keeps GTK4 apps on the Mesa-only EGL path above.
  export GSK_RENDERER=ngl
fi

if [ -n "$_gpu_nvidia_card" ]; then
  # NVIDIA is offload-only here. Vulkan enumeration ignores AQ_DRM_DEVICES, so
  # games still see the dGPU: DXVK sorts adapters discrete-first and
  # vkd3d-proton follows that adapter by LUID, so Proton titles land on NVIDIA
  # with no per-game config. Native OpenGL games still need per-game prime-run.
  # The device-selector vars (__NV_PRIME_RENDER_OFFLOAD /
  # __GLX_VENDOR_LIBRARY_NAME / GBM_BACKEND) stay out — they must be per-game
  # launch options, or they force the Intel-primary compositor onto NVIDIA and
  # black-screen it. The flags below are only read by Proton, inert otherwise.
  export PROTON_DXVK_LOWLATENCY=1
  export PROTON_HIDE_NVIDIA_GPU=0
  export PROTON_ENABLE_NVAPI=1
  export DXVK_ENABLE_NVAPI=1
  export PROTON_ENABLE_NGX_UPDATER=1
  export VKD3D_CONFIG=dxr,dxr11
  export VKD3D_FEATURE_LEVEL=12_2
fi

unset _gpu_intel_card _gpu_nvidia_card
unset -f _card_for_vendor
