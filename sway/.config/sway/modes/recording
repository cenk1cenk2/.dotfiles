# vim:ft=swayconfig

### Recording Mode

set $mode_recording "ó°•§ Recording: (r) toggle | (p) pause | (o) OBS | (s/S) speechâ†’type | (c/C) speechâ†’clipboard | (a/A) speechâ†’ask/hide | (w/W) copywriter/kill | (q/Q) stop recording/speech | <ESC>"

mode $mode_recording {
        # Toggle recording (start/stop)
        bindsym r exec $recorder toggle, mode "default"

        # Toggle pause/resume
        bindsym p exec $recorder pause, mode "default"

        # Open OBS window
        bindsym o exec $recorder open, mode "default"

        # Stop recording
        bindsym q exec $recorder stop, mode "default"

        # Speech-to-text direct typing with AI enrichment
        bindsym s exec $speech toggle --output type --enrich, mode "default"

        # Speech-to-text direct typing (raw, no enrichment)
        bindsym Shift+s exec $speech toggle --output type, mode "default"

        # Speech-to-text to clipboard with AI enrichment
        bindsym c exec $speech toggle --output clipboard --enrich, mode "default"

        # Speech-to-text to clipboard (raw, no enrichment)
        bindsym Shift+c exec $speech toggle --output clipboard, mode "default"

        # Speech-to-text piped into the ask overlay (new session or live-forward)
        bindsym a exec zsh -c '$HOME/.config/wayland/scripts/speech.py toggle --output stdout | $HOME/.config/wayland/scripts/ask.py toggle --input stdin', mode "default"

        # Toggle the ask overlay (hides/shows without ending the session)
        bindsym Shift+a exec $ask toggle-window, mode "default"

        # Copywriter: refine clipboard through AI
        bindsym w exec $copywriter run clipboard, mode "default"

        # Kill copywriter
        bindsym Shift+w exec $copywriter kill, mode "default"

        # Stop speech-to-text
        bindsym Shift+q exec $speech kill, mode "default"

        # Exit recording mode
        bindsym Escape mode "default"
}

## Launch // Recording Mode ##
bindsym $mod+r mode $mode_recording
