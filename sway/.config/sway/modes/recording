# vim:ft=swayconfig

### Recording Mode

set $mode_recording "󰕧 Recording: (r/R) toggle/pause | (o) OBS | (s/S) speech→type | (c/C) speech→clipboard | (a/A) speech→pilot/hide | (p/P) plan/hide | (w/W) copywriter/kill | (q/Q) stop speech/recording | <ESC>"

mode $mode_recording {
        # Toggle recording (start/stop)
        bindsym r exec $recorder toggle, mode "default"

        # Pause/resume recording — moved off `p` (now the plan-pilot session key)
        bindsym Shift+r exec $recorder pause, mode "default"

        # Open OBS window
        bindsym o exec $recorder open, mode "default"

        # Stop recording
        bindsym Shift+q exec $recorder stop, mode "default"

        # Speech-to-text direct typing with AI enrichment
        bindsym s exec $speech toggle --output type --enrich, mode "default"

        # Speech-to-text direct typing (raw, no enrichment)
        bindsym Shift+s exec $speech toggle --output type, mode "default"

        # Speech-to-text to clipboard with AI enrichment
        bindsym c exec $speech toggle --output clipboard --enrich, mode "default"

        # Speech-to-text to clipboard (raw, no enrichment)
        bindsym Shift+c exec $speech toggle --output clipboard, mode "default"

        # `ask` pilot overlay — default provider, speech-piped new
        # session (or live-forward into an existing one). Session
        # suffix `ask` keeps its socket / app-id isolated from `plan`.
        bindsym a exec zsh -c '$HOME/.config/wayland/scripts/speech.py toggle --output stdout | $HOME/.config/wayland/scripts/pilot.py --session ask toggle --input stdin', mode "default"

        # Hide/show the already-running `ask` pilot.
        bindsym Shift+a exec $pilot --session ask toggle, mode "default"

        # `plan` pilot overlay — opencode+glm-5.1:cloud, cwd=~/notes.
        bindsym p exec zsh -c '$HOME/.config/wayland/scripts/speech.py toggle --output stdout | $HOME/.config/wayland/scripts/pilot.py --session plan toggle --converse-provider opencode --converse-model glm-5.1:cloud --cwd ~/notes --input stdin', mode "default"

        # Hide/show the already-running `plan` pilot.
        bindsym Shift+p exec $pilot --session plan toggle, mode "default"

        # Copywriter: refine clipboard through AI
        bindsym w exec $copywriter run clipboard, mode "default"

        # Kill copywriter
        bindsym Shift+w exec $copywriter kill, mode "default"

        # Stop speech-to-text
        bindsym q exec $speech kill, mode "default"

        # Exit recording mode
        bindsym Escape mode "default"
}

## Launch // Recording Mode ##
bindsym $mod+r mode $mode_recording
